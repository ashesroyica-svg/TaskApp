@page
@model Todo.Web.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center auth-bg py-4">
    <div class="auth-card card shadow border-0" style="width: 480px; max-width: 95vw;">
        <div class="card-header bg-primary text-white text-center py-4 border-0 rounded-top-3">
            <div class="mb-2">
                <i class="bi bi-person-plus" style="font-size: 2.5rem;"></i>
            </div>
            <h4 class="fw-bold mb-0">Create Account</h4>
            <p class="mb-0 small opacity-75">ICA Employee Todo</p>
        </div>
        <div class="card-body p-4">
            @if (Model.ErrorMessage != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Input.Username" class="form-label fw-medium">Username</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="bi bi-person text-muted"></i>
                        </span>
                        <input asp-for="Input.Username" class="form-control border-start-0 ps-0"
                               placeholder="johndoe" autocomplete="username" />
                    </div>
                    <span asp-validation-for="Input.Username" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Email" class="form-label fw-medium">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="bi bi-envelope text-muted"></i>
                        </span>
                        <input asp-for="Input.Email" class="form-control border-start-0 ps-0"
                               placeholder="you@icagroup.in" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Input.Password" class="form-label fw-medium">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="bi bi-lock text-muted"></i>
                        </span>
                        <input asp-for="Input.Password" class="form-control border-start-0 ps-0"
                               placeholder="Min 8 chars, 1 uppercase, 1 number" autocomplete="new-password" id="passwordNew" />
                        <button class="btn btn-outline-secondary border-start-0" type="button"
                                onclick="togglePassword('passwordNew', this)" title="Show/hide password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-medium">Confirm Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-body border-end-0">
                            <i class="bi bi-lock-fill text-muted"></i>
                        </span>
                        <input asp-for="Input.ConfirmPassword" class="form-control border-start-0 ps-0"
                               placeholder="Repeat password" autocomplete="new-password" id="passwordConfirm" />
                        <button class="btn btn-outline-secondary border-start-0" type="button"
                                onclick="togglePassword('passwordConfirm', this)" title="Show/hide password">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                    <i class="bi bi-person-check me-2"></i>Create Account
                </button>
            </form>
        </div>
        <div class="card-footer bg-transparent text-center py-3 border-0">
            <small class="text-muted">
                Already have an account?
                <a asp-page="/Auth/Login" class="fw-medium text-primary text-decoration-none">Sign in here</a>
            </small>
        </div>
    </div>
</div>
