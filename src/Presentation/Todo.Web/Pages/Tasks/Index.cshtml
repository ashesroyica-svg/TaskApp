@page
@model Todo.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tasks";
    var priorityColors = new Dictionary<Domain.Entities.TaskPriority, string>
    {
        [Domain.Entities.TaskPriority.Low]    = "success",
        [Domain.Entities.TaskPriority.Medium] = "warning",
        [Domain.Entities.TaskPriority.High]   = "danger"
    };
}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-4">
    <div>
        <h2 class="fw-bold mb-1"><i class="bi bi-list-check me-2 text-primary"></i>Tasks</h2>
        <p class="text-muted mb-0">Manage your work tasks</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTaskModal">
        <i class="bi bi-plus-lg me-2"></i>New Task
    </button>
</div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (Model.ErrorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@Model.ErrorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filters -->
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-body"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="Search" value="@Model.Search" class="form-control"
                           placeholder="Search tasks..." />
                </div>
            </div>
            <div class="col-md-4">
                <select name="ProjectFilter" class="form-select">
                    <option value="">All Projects</option>
                    @foreach (var p in Model.Projects)
                    {
                        <option value="@p.Id" selected="@(Model.ProjectFilter == p.Id)">@p.Name</option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-page="./Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x-lg"></i>
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Task list -->
@if (!Model.Tasks.Items.Any())
{
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size:3.5rem;"></i>
            <p class="text-muted mt-3 mb-2 fs-5">No tasks found.</p>
            <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                <i class="bi bi-plus-lg me-1"></i>Create your first task
            </button>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        @foreach (var task in Model.Tasks.Items)
        {
            var badgeColor = priorityColors.GetValueOrDefault(task.Priority, "secondary");
            <div class="col-12">
                <div class="card shadow-sm border-0 task-card @(task.IsCompleted ? "task-completed" : "") @(task.IsOverdue && !task.IsCompleted ? "border-start border-danger border-3" : "")">
                    <div class="card-body d-flex align-items-start gap-3 py-3">
                        <!-- Toggle checkbox -->
                        <form method="post" asp-page-handler="Toggle" class="flex-shrink-0 mt-1">
                            <input type="hidden" name="id" value="@task.Id" />
                            <input type="hidden" name="isCompleted" value="@(!task.IsCompleted ? "true" : "false")" />
                            <input type="hidden" name="Page" value="@Model.Page" />
                            <input type="hidden" name="Search" value="@Model.Search" />
                            <input type="hidden" name="ProjectFilter" value="@Model.ProjectFilter" />
                            <button type="submit" class="btn btn-link p-0 text-decoration-none" title="@(task.IsCompleted ? "Mark incomplete" : "Mark complete")">
                                <i class="bi @(task.IsCompleted ? "bi-check-circle-fill text-success" : "bi-circle text-muted") fs-5"></i>
                            </button>
                        </form>

                        <!-- Task content -->
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
                                <div>
                                    <span class="fw-medium @(task.IsCompleted ? "text-decoration-line-through text-muted" : "")">
                                        @task.Task
                                    </span>
                                    <div class="d-flex flex-wrap gap-2 mt-1">
                                        <span class="badge bg-@badgeColor bg-opacity-15 text-@badgeColor border border-@badgeColor border-opacity-25">
                                            <i class="bi bi-flag-fill me-1"></i>@task.PriorityLabel
                                        </span>
                                        @if (task.ProjectName != null)
                                        {
                                            <span class="badge bg-body-secondary text-body-secondary border"
                                                  style="border-color:@task.ProjectColor !important;">
                                                <span class="me-1" style="color:@task.ProjectColor">●</span>@task.ProjectName
                                            </span>
                                        }
                                        @if (task.DueDate.HasValue)
                                        {
                                            var dueCss = task.IsOverdue && !task.IsCompleted ? "text-danger" : "text-muted";
                                            <span class="small @dueCss">
                                                <i class="bi bi-calendar3 me-1"></i>@task.DueDate.Value.ToString("MMM d, yyyy")
                                                @if (task.IsOverdue && !task.IsCompleted)
                                                {
                                                    <span class="badge bg-danger ms-1">Overdue</span>
                                                }
                                            </span>
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(task.Description))
                                    {
                                        <p class="text-muted small mt-1 mb-0">@task.Description</p>
                                    }
                                </div>
                                <form method="post" asp-page-handler="Delete"
                                      onsubmit="return confirm('Delete this task?')">
                                    <input type="hidden" name="id" value="@task.Id" />
                                    <input type="hidden" name="Page" value="@Model.Page" />
                                    <input type="hidden" name="Search" value="@Model.Search" />
                                    <input type="hidden" name="ProjectFilter" value="@Model.ProjectFilter" />
                                    <button type="submit" class="btn btn-link text-danger p-0" title="Delete task">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.Tasks.TotalPages > 1)
    {
        <nav aria-label="Task pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Tasks.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-page="@(Model.Tasks.Page - 1)"
                       asp-route-search="@Model.Search"
                       asp-route-projectFilter="@Model.ProjectFilter">
                        <i class="bi bi-chevron-left"></i>
                    </a>
                </li>
                @for (int i = Math.Max(1, Model.Tasks.Page - 2); i <= Math.Min(Model.Tasks.TotalPages, Model.Tasks.Page + 2); i++)
                {
                    <li class="page-item @(i == Model.Tasks.Page ? "active" : "")">
                        <a class="page-link" asp-page="./Index"
                           asp-route-page="@i"
                           asp-route-search="@Model.Search"
                           asp-route-projectFilter="@Model.ProjectFilter">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Tasks.Page >= Model.Tasks.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="./Index"
                       asp-route-page="@(Model.Tasks.Page + 1)"
                       asp-route-search="@Model.Search"
                       asp-route-projectFilter="@Model.ProjectFilter">
                        <i class="bi bi-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">
            Showing @((Model.Tasks.Page - 1) * Model.Tasks.PageSize + 1)–@(Math.Min(Model.Tasks.Page * Model.Tasks.PageSize, Model.Tasks.TotalCount))
            of @Model.Tasks.TotalCount tasks
        </p>
    }
}

<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1" aria-labelledby="createTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post" asp-page-handler="Create">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="createTaskModalLabel">
                        <i class="bi bi-plus-circle me-2 text-primary"></i>New Task
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body pt-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="NewTask.Task" class="form-label fw-medium">Task Title <span class="text-danger">*</span></label>
                        <input asp-for="NewTask.Task" class="form-control" placeholder="What needs to be done?" />
                        <span asp-validation-for="NewTask.Task" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewTask.Description" class="form-label fw-medium">Description</label>
                        <textarea asp-for="NewTask.Description" class="form-control" rows="3"
                                  placeholder="Optional details..."></textarea>
                        <span asp-validation-for="NewTask.Description" class="text-danger small"></span>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="NewTask.Priority" class="form-label fw-medium">Priority</label>
                            <select asp-for="NewTask.Priority" class="form-select">
                                <option value="0">Low</option>
                                <option value="1" selected>Medium</option>
                                <option value="2">High</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NewTask.DueDate" class="form-label fw-medium">Due Date</label>
                            <input asp-for="NewTask.DueDate" type="date" class="form-control"
                                   min="@DateTime.Today.ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="NewTask.DueDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="NewTask.ProjectId" class="form-label fw-medium">Project</label>
                            <select asp-for="NewTask.ProjectId" class="form-select">
                                <option value="">No Project</option>
                                @foreach (var p in Model.Projects)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg me-2"></i>Create Task
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Re-open modal on validation error
        @if (Model.ErrorMessage != null || !ModelState.IsValid)
        {
            <text>
            document.addEventListener('DOMContentLoaded', function () {
                var modal = new bootstrap.Modal(document.getElementById('createTaskModal'));
                modal.show();
            });
            </text>
        }
    </script>
}
