@page
@model Todo.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center">
    <div class="text-center">
        <i class="bi bi-exclamation-triangle text-warning" style="font-size:4rem;"></i>
        <h1 class="mt-3 fw-bold">Something went wrong</h1>
        <p class="text-muted">An unexpected error has occurred.</p>
        @if (Model.RequestId != null)
        {
            <p class="small text-muted">Request ID: <code>@Model.RequestId</code></p>
        }
        <a asp-page="/Dashboard/Index" class="btn btn-primary mt-2">
            <i class="bi bi-house me-2"></i>Back to Dashboard
        </a>
    </div>
</div>
